# ============================================
# Colon Pipeline .gitignore
# Purpose: Exclude large data files from version control
# ============================================

# Large data files (stored on S3, not git)
data/*.parquet
data/*.csv

# Raw curated data (40GB+, S3-based)
curated_data/

# Runtime logs
logs/

# Results (generated)
results/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temp
*.tmp
*.temp
/tmp/
.cache/

# Environment
.env
*.env

# Nextflow work directory (if local)
work/
.nextflow/
.nextflow.log*

# Large files generally (fallback)
*.gctx
*.gctx.gz
*.h5
